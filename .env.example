APP_HOST=0.0.0.0
APP_PORT=8129

# Public URL used by XiaoDu to access this service.
APP_BASE_URL=

# Internal Home Assistant URL used by the service container.
HA_BASE_URL=

# Recommended HA auth mode: refresh token + client id.
HA_REFRESH_TOKEN=
HA_CLIENT_ID=https://xiaodu-dbp.baidu.com

# Shared secret used only between HA integration and the service container.
INTERNAL_API_TOKEN=replace_with_random_internal_token

# The following defaults are handled by the program automatically and usually
# do not need to be written during first deployment:
# AUTH_MODE=homeassistant
# XIAODU_CLIENT_ID=dueros
# XIAODU_ALLOWED_REDIRECT_URIS=https://xiaodu.baidu.com/saiya/auth/,https://xiaodu-dbp.baidu.com/saiya/auth/
# XIAODU_PRIVATE_KEY_PATH=/data/xiaodu_private_key.pem
# DEVICE_CONFIG_PATH=/data/devices.yaml
# TOKEN_STORE_PATH=/data/token_store.json
# SERVICE_ENV_PATH=/data/service.env
